# ──────────────────────────────────────────────────────────────────────────────
# BA Jira Agent — Streamlit Secrets Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml for local dev:
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# For HuggingFace Spaces, set these in Space Settings → Repository Secrets.
# HF Spaces injects them as environment variables at runtime.
# ──────────────────────────────────────────────────────────────────────────────

# REQUIRED: Your DeepSeek API key
# Get it at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# OPTIONAL: Override the LLM model name
# Supported models: deepseek-chat, deepseek-reasoner
# Default: deepseek-chat
# LLM_MODEL = "deepseek-chat"

# OPTIONAL: Override the DeepSeek API base URL
# Default: https://api.deepseek.com/v1
# LLM_BASE_URL = "https://api.deepseek.com/v1"

# OPTIONAL: LLM temperature (0-2, lower = more deterministic)
# Default: 0
# LLM_TEMPERATURE = "0"

# OPTIONAL: Override the Streamlit app port
# Default: 8503
# APP_PORT = "8503"
